# Node
node_modules/

# Capacitor / iOS: der komplette Ordner wird auf dem Mac per `npx cap add ios`
# aus capacitor.config.ts + resources/ neu erzeugt (dünne Hülle, server.url-
# Ansatz — kein eigener nativer Code). Daher NICHT versionieren, sonst landen
# riesige Xcode-/Pods-Artefakte im Repo. Bei Bedarf jederzeit neu generierbar.
ios/
*.xcuserstate
xcuserdata/

# Build-Artefakte / Signierung — NIEMALS committen
*.ipa
*.mobileprovision
*.p12
*.p8
*.cer
*.certSigningRequest
ExportOptions.plist

# macOS
.DS_Store
